# Copy this file to .env and fill in your Supabase credentials.
# Never commit .env to git.

# Supabase project URL — found in: Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key (server-side only, full DB access, bypasses RLS)
# Found in: Supabase dashboard → Settings → API → service_role key
SUPABASE_KEY=your-service-role-key-here
